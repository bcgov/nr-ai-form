{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "args": [
        "What is BCeiD?"
      ]
    },
    {
      "name": "Launch Conversation Agent",
      "type": "debugpy",
      "request": "launch",
      "module": "conversationagent",
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "What is BCeiD?"
      ],
      "cwd": "${workspaceFolder}/agentic_ai_backend/agents/conversationagent",
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}