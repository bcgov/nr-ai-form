AZURE_SEARCH_QUERY_ANSWER="extractive"
AZURE_SEARCH_QUERY_ANSWER_COUNT=3
AZURE_SEARCH_QUERY_LANGUAGE="en-us"


AGENT_TEMPERATURE=0.1
AGENT_MAX_TOKENS=800
