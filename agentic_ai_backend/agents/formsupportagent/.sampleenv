# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION="2024-10-21"

HOST="0.0.0.0"
PORT="8001"

AZURE_BLOBSTORAGE_CONNECTIONSTRING=
AZURE_BLOBSTORAGE_CONTAINER=

# Asset source switch
# true: use local formdefinitions/ and prompttemplates/ when developing (requires local files, but faster for development)
# false: use Azure Blob storage services when configured (default behavior)
USE_LOCAL_FORM_ASSETS=false
