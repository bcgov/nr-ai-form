{
    "$schema": "https://a2a-protocol.org/schema/agent-card.json",
    "identity": {
        "name": "FormSupportAgent",
        "author": "BC Government",
        "description": "A form support agent for BC Government.",
        "avatarUrl": "",
        "version": "1.0.0",
        "license": "MIT"
    },
    "capabilities": [
        {
            "id": "form_support_skill",
            "name": "BC Government Form Support",
            "description": "Answers questions about BC Government's forms using Azure AI Search.",
            "tags": [
                "form-support",
                "permit",
                "search"
            ],
            "input": {
                "type": "text",
                "examples": [
                    "What is North coast Transmission Pipeline ?",
                    "What is Dam Proposal Project report ?",
                    "How to get a fishing license ?"
                ]
            },
            "output": {
                "type": "text"
            }
        }
    ],
    "interaction": {
        "baseUrl": "http://localhost:8001",
        "endpoints": {
            "invoke": {
                "url": "/invoke",
                "method": "POST"
            },
            "discovery": {
                "url": "/.well-known/agent.json",
                "method": "GET"
            }
        }
    }
}