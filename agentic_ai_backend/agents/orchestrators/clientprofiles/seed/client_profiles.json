  {
    "id": "11111111-1111-4111-8111-111111111111",
    "clientId": "11111111-1111-4111-8111-111111111111",
    "clientName": "Water Permit App",
    "corsOrigins": [
      "https://test.j200.gov.bc.ca/*",
      "http://localhost*"
    ],
    "tenantResources": {
      "blobConnectionString": "<key-vault-secret-for-connection-string>",
      "containerName": "assets",
      "prompts": {
        "dispatcher": "tenants/water/agentprompts/dispatcher",
        "aggregator": "tenants/water/agentprompts/aggregrator"
      }
    },
    "subAgents": [
      {
        "agentType": "conversationAgent",
        "enabled": true,
        "promptPath": "tenants/water/agentprompts/conversationagent/instructions.md",
        "config": {
          "indexName": "rag-bc-fish",
          "knowledgeAgentName": "knowledgebase-bc-waterpermit-dev",
          "azureSearchApiKey":"<azure-search-api-key-or-key-vault-secret-for-api-key>"
        }
      },
      {
        "agentType": "formSupportAgent",
        "enabled": true,
        "promptPath": "tenants/water/agentprompts/formsupportagent/instructions.md",
        "config": {
          "formDefinitionContainer": "tenants/water/formdefinitions",
          "stepBasedPromptContainer": "tenants/water/prompttemplates"
        }
      }
    ]
  },
